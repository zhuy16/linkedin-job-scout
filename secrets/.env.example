# =============================================================================
#  secrets/.env.example — credential template
#
#  SETUP: copy this file and fill in your real values:
#      cp secrets/.env.example secrets/.env
#
#  secrets/.env is GITIGNORED and will never be committed or shared.
#  Never put real credentials in this .example file.
# =============================================================================

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# Your regular LinkedIn login email and password.
# The scraper logs in as you in a real Chrome browser — the session will appear
# in your LinkedIn login history like any other device.
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Anthropic API (LLM scoring) ───────────────────────────────────────────────
# Get your key at: https://console.anthropic.com → API Keys
#
# IMPORTANT — workspace mismatch gotcha:
#   Anthropic has multiple "workspaces" under one account. Credits and API keys
#   are per-workspace. Make sure the key you paste here belongs to the same
#   workspace where you loaded credits.
#
# Cost estimate:
#   claude-sonnet-4-5 costs ~$0.003 per job scored (3/10ths of a cent).
#   Scoring 25 jobs/day = ~$0.075/day = ~$2.25/month.
#   Load at least $5 to start. Top up at: https://console.anthropic.com/billing
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Used to send your daily job digest. Gmail requires an App Password — your
# regular Gmail password will NOT work here.
#
# How to create a Gmail App Password (2 minutes):
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to App Passwords:        https://myaccount.google.com/apppasswords
#   3. Create one, name it "Job Scout"
#   4. Paste the 16-character password below (spaces don't matter)
#
# Cost: free (Gmail SMTP is free for personal use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send the daily digest (can be the same as SMTP_USER,
# or any other email address you prefer).
ALERT_EMAIL=your_email@example.com
