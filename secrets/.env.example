# ══════════════════════════════════════════════════════════════════════════════
# LinkedIn Job Scout Agent — credentials template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file:   cp secrets/.env.example secrets/.env
# Then fill in your real values.  secrets/.env is gitignored — never commit it.
# ══════════════════════════════════════════════════════════════════════════════

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# ── Email alerts (Gmail recommended) ─────────────────────────────────────────
# For Gmail you MUST use an App Password, not your regular password.
# How to create one:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create a new app password (name it "Job Scout" or anything)
#   4. Paste the 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Where to deliver job alert emails (can be the same as SMTP_USER)
ALERT_EMAIL=your_email@example.com

# ── Optional overrides ────────────────────────────────────────────────────────
# DB_PATH=data/jobs.db
